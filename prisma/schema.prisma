generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LmsProvider {
  LEARNING_SUITE
  CANVAS
  GRADESCOPE
  MAX
}

enum AssignmentStatus {
  OPEN
  COMPLETED
  OVERDUE
}

enum AssignmentType {
  HOMEWORK
  QUIZ
  EXAM
  PROJECT
  READING
  DISCUSSION
  OTHER
}

enum CalendarProvider {
  GOOGLE
  APPLE
  ICS
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String?
  timezone           String             @default("America/Denver")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  assignments        Assignment[]
  connectorAccounts  ConnectorAccount[]
  reminders          ReminderSetting?
  duplicateGroups    DuplicateGroup[]
  calendarConnections CalendarConnection[]
}

model ConnectorAccount {
  id            String      @id @default(cuid())
  userId        String
  provider      LmsProvider
  externalUserId String?
  encryptedToken String?
  refreshToken  String?
  cursor        String?
  checksum      String?
  lastSyncAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Assignment {
  id                 String           @id @default(cuid())
  userId             String
  source             LmsProvider
  sourceAssignmentId String
  sourceCourseId     String
  title              String
  description        String?
  dueAt              DateTime
  courseName         String
  courseColor        String?
  url                String?
  status             AssignmentStatus @default(OPEN)
  assignmentType     AssignmentType   @default(OTHER)
  lastSeenAt         DateTime         @default(now())
  hash               String
  dedupeGroupId      String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  dedupeGroup        DuplicateGroup?  @relation(fields: [dedupeGroupId], references: [id], onDelete: SetNull)

  @@unique([userId, source, sourceAssignmentId])
  @@index([userId, dueAt])
  @@index([userId, sourceCourseId, dueAt])
  @@index([userId, assignmentType])
}

model DuplicateGroup {
  id                 String       @id @default(cuid())
  userId             String
  canonicalAssignmentId String
  dedupeConfidence   Float
  needsReview        Boolean      @default(true)
  resolvedAt         DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments        Assignment[]

  @@index([userId, needsReview])
}

model ReminderSetting {
  id                String    @id @default(cuid())
  userId            String    @unique
  enabled           Boolean   @default(true)
  emailEnabled      Boolean   @default(true)
  inAppEnabled      Boolean   @default(true)
  remindHoursBefore Int       @default(24)
  snoozeUntil       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalendarConnection {
  id               String           @id @default(cuid())
  userId           String
  provider         CalendarProvider
  externalCalendarId String?
  encryptedToken   String?
  syncEnabled      Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model CalendarEventMap {
  id                   String   @id @default(cuid())
  userId               String
  canonicalAssignmentId String
  provider             CalendarProvider
  externalEventId      String
  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())

  @@unique([userId, canonicalAssignmentId, provider])
}

model AssignmentChangeLog {
  id            String   @id @default(cuid())
  assignmentId  String
  field         String
  oldValue      String?
  newValue      String?
  changedAt     DateTime @default(now())

  @@index([assignmentId, changedAt])
}
